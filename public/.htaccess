# Enable rewrite engine
RewriteEngine On

# ============================================
# SERVIR ARCHIVOS ESTATICOS DIRECTAMENTE
# ============================================

# Si el archivo existe, servirlo directamente sin pasar por PHP
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(uploads/.*)$ $1 [L]

# ============================================
# API ENDPOINTS
# ============================================

# Redirigir /api/* a los archivos PHP correspondientes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/$1.php [QSA,L]

# ============================================
# AUTHENTICATION HEADERS
# ============================================

# Pass Authorization header to PHP
RewriteCond %{HTTP:Authorization} ^(.*)
RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

# Alternative for CGI/FastCGI
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# ============================================
# CORS PREFLIGHT
# ============================================

# Handle OPTIONS preflight
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# ============================================
# DEFAULT: Redirigir todo a index.html (SPA)
# ============================================

# Si no es un archivo existente, redirigir a index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
