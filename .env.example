# Database Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=payments_db
MYSQL_USER=user
MYSQL_PASSWORD=password

# JWT Configuration
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# CORS - Comma separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email Configuration (SMTP + IMAP)
# For Gmail: Use App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# For cPanel: Use mail.yourdomain.com (usually same for SMTP and IMAP)

# SMTP Settings (for sending emails)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=cobranza@yourdomain.com
SMTP_PASS=your-password
SMTP_FROM_NAME=Tu Empresa
SMTP_FROM_EMAIL=cobranza@yourdomain.com

# IMAP Settings (for reading replies) - cPanel
IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_USER=cobranza@yourdomain.com
IMAP_PASS=your-password
IMAP_SSL=true
